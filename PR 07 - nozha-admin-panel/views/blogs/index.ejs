<!doctype html>
<html class="no-js" lang="">

<head>
    <%- include('../partials/head') %>
</head>

<body class="">
    <div class="bmd-layout-container bmd-drawer-f-l avam-container animated bmd-drawer-in">
        <%- include('../partials/header') %>
        <%- include('../partials/sidebar', { active: 'blogs' }) %>

        <main class="bmd-layout-content">
            <div class="container-fluid">

                <div class="row">
                    <div class="page-header breadcrumb-header p-3 mr-2 ml-2 m-2">
                        <div class="row align-items-end ">
                            <div class="col-lg-8">
                                <div class="page-header-title text-left-rtl">
                                    <div class="d-inline">
                                        <h3 class="lite-text ">Blogs</h3>
                                        <span class="lite-text text-gray">Manage all blog posts</span>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4">
                                <ol class="breadcrumb float-sm-right">
                                    <li class="breadcrumb-item "><a href="/"><i class="fas fa-home"></i></a></li>
                                    <li class="breadcrumb-item active">Blogs</li>
                                </ol>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="jumbotron shade pt-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h4 class="m-0">All Blogs</h4>
                        <a href="/blogs/new" class="btn shade f-primary"><i class="fas fa-plus-circle mr-2"></i>Add Blog</a>
                    </div>
                    <hr class="hr-dashed">

                    <% if (blogs.length === 0) { %>
                        <p class="text-muted">No blogs created yet. <a href="/blogs/new">Create the first blog</a>.</p>
                    <% } else { %>
                        <div class="row">
                            <% blogs.forEach(blog => { %>
                                <div class="col-md-6 col-lg-4 mb-4">
                                    <div class="card shade h-100">
                                        <% if (blog.image) { %>
                                            <img src="<%= blog.image %>" class="card-img-top" alt="<%= blog.title %>" style="height:180px;object-fit:cover;">
                                        <% } %>
                                        <div class="card-body d-flex flex-column">
                                            <h5 class="card-title"><%= blog.title %></h5>
                                            <p class="card-text text-muted small mb-1">
                                                By <%= blog.author ? blog.author.name : '—' %> · <%= blog.createdAt.toDateString() %>
                                            </p>
                                            <p class="card-text">
                                                <%= blog.content.length > 100 ? blog.content.slice(0, 100) + '...' : blog.content %>
                                            </p>
                                            <div class="mt-auto d-flex justify-content-between">
                                                <a href="/blogs/<%= blog._id %>/edit" class="btn btn-sm shade f-primary">
                                                    <i class="fas fa-edit"></i> Edit
                                                </a>
                                                <form action="/blogs/<%= blog._id %>?_method=DELETE" method="POST"
                                                      onsubmit="return confirm('Are you sure you want to delete this blog?');">
                                                    <button type="submit" class="btn btn-sm shade f-danger">
                                                        <i class="fas fa-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>

            </div>
        </main>
    </div>

    <%- include('../partials/scripts') %>
</body>

</html>
