<!doctype html>
<html class="no-js" lang="">

<head>
    <%- include('partials/head') %>
</head>

<body class="">
    <div class="bmd-layout-container bmd-drawer-f-l avam-container animated ">
        <main class="bmd-layout-content">
            <div class="container-fluid">
                <div class="main_wrapper">

                    <div class="row ">
                        <div class="col-md-5 card shade mw-center mh-center">
                            <img src="/svg/logo.svg" alt="Nozha" class="mw-center " height="130" width="300">
                            <hr class="hr-dashed m-0">
                            <p class="text-muted small text-center">
                                Enter the OTP sent to your email and your new password.
                            </p>
                            <form action="/verify-otp" method="POST">
                                <div class="form-group m-0">
                                    <label for="otp">OTP</label>
                                    <input type="text" class="form-control" id="otp" name="otp"
                                        placeholder="Enter OTP" required>
                                </div>
                                <div class="form-group m-0">
                                    <label for="newPassword">New Password</label>
                                    <input type="password" class="form-control" id="newPassword" name="newPassword"
                                        placeholder="New password" required>
                                </div>
                                <div class="form-group m-0">
                                    <label for="confirmPassword">Confirm New Password</label>
                                    <input type="password" class="form-control" id="confirmPassword"
                                        name="confirmPassword" placeholder="Confirm new password" required>
                                </div>
                                <button type="submit" class="btn shade f-primary btn-block">Verify OTP & Reset Password</button>
                            </form>
                            <p class="text-center pt-3">
                                <a href="/login">Back to Login</a>
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </main>
    </div>

    <%- include('partials/scripts') %>
</body>

</html>
