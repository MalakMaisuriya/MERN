<div class="container-fluid ">

				<!-- content -->

				<div class="row">
					<div class="page-header breadcrumb-header p-3 mr-2 ml-2 m-2">
						<div class="row align-items-end ">
							<div class="col-lg-8">
								<div class="page-header-title text-left-rtl">
									<div class="d-inline">
										<h3 class="lite-text ">Toast</h3>
										<span class="lite-text text-gray">Options of Toast </span>
									</div>
								</div>
							</div>
							<div class="col-lg-4">
								<ol class="breadcrumb float-sm-right">
									<li class="breadcrumb-item "><a href="#"><i class="fas fa-home"></i></a></li>
									<li class="breadcrumb-item "><a href="#">Extra</a></li>
									<li class="breadcrumb-item active">Toast</li>
								</ol>
							</div>
						</div>
					</div>
				</div>


				<div class="jumbotron shade pt-5">
					<h1>Toast</h1>
					<p class="c-grey font-weight-light font-italic">toastr is a Javascript library for Gnome / Growl
						type non-blocking notifications. jQuery is required. The goal is to create a simple core
						library that can be customized and extended. <br>
						<div class="alert col-12 d-flex alert-danger alert-shade-white bd-side fade show" role="alert">
							<strong class="pr-1 pl-1">Heads Up!</strong> You have to call toast with JavaScript , read
							the instruction
							from <a class="pl-1 pr-1" href="https://codeseven.github.io/toastr/">toastr</a> site .

						</div>
						<h4 class="c-grey pt-3 pb-3">Toast</h4>
						<h6 class="fnt-code text-dir-ltr mb-0 pb-0">onclick="toastr.success('TEXT MESSAGE', 'TITLE',
							{timeOut: 5s})" </h6>
						<hr class="mt-0 mb-4">
						<div class="row  ">
							<div class="c-grey col-3 ">
								<a href="#" class="btn text-center shade f-first"
									onclick="toastr.success('We do have the Kapua suite available.', 'Turtle Bay Resort', {timeOut: 105000})">success</a>
							</div>
							<div class="c-grey col-3 ">
								<a href="#" class="btn text-center shade f-warning"
									onclick="toastr.warning('We do have the Kapua suite available.', 'Turtle Bay Resort', {timeOut: 105000})">warning</a>
							</div>
							<div class="c-grey col-3 ">
								<a href="#" class="btn text-center shade f-danger"
									onclick="toastr.error('We do have the Kapua suite available.', 'Turtle Bay Resort', {timeOut: 105000})">error</a>
							</div>
							<div class="c-grey col-3 ">
								<a href="#" class="btn text-center shade f-primary"
									onclick="toastr.info('We do have the Kapua suite available.', 'Turtle Bay Resort', {timeOut: 105000})">info</a>
							</div>

						</div>

						<!-- toast -->



						<!-- end of content -->
